#!/usr/bin/env bash
if [[ "$1" == "-h" || "$1" == "--help" || $# -lt 1 ]]; then
  echo "Usage: $(basename "$0") <theme_id>"
  echo ""
  echo "Fetches a theme by ID and pretty-prints it."
  echo ""
  echo "Examples:"
  echo "  $(basename "$0") 1"
  exit 0
fi

curl -s "http://localhost:5000/api/themes/$1" | jq --indent 2 '.'
