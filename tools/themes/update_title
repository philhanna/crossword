#!/usr/bin/env bash
if [[ "$1" == "-h" || "$1" == "--help" || $# -lt 2 ]]; then
  echo "Usage: $(basename "$0") <theme_id> <title>"
  echo ""
  echo "Updates the title of a theme."
  echo ""
  echo "Examples:"
  echo "  $(basename "$0") 1 \"Big Rivers\""
  exit 0
fi

theme_id="$1"
title="$2"
payload=$(jq -n --arg title "$title" '{"title": $title}')

curl -s -X PUT "http://localhost:5000/api/themes/$theme_id" \
  -H 'Content-Type: application/json' \
  -d "$payload" \
  | jq --indent 2 '.'
